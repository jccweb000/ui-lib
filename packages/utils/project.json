{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "utils",
  "projectType": "library",
  "sourceRoot": "packages/utils/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "packages/utils",
        "command": "pnpm run build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/utils",
        "command": "pnpm run test"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/utils",
        "command": "pnpm run lint"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/utils",
        "command": "pnpm run typecheck"
      }
    }
  },
  "tags": [
    "scope:shared",
    "type:utils"
  ]
}
